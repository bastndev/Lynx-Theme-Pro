{
  "$schema": "vscode://schemas/color-theme",
  "name": "Lynx Liquid Glass",
  "type": "dark",
  "semanticClass": "theme.liquid-glass",
  "semanticHighlighting": true,
  "colors": {
    "statusBar.background": "#00000000",
    "statusBar.noFolderBackground": "#00000000",
    "statusBar.debuggingBackground": "#00000000",
    "titleBar.activeBackground": "#00000000",
    "titleBar.inactiveBackground": "#00000000",
    "activityBar.background": "#00000000",
    "sideBar.background": "#00000000",
    "sideBarSectionHeader.background": "#00000000",
    "editor.background": "#0c11188c",
    "editorGroupHeader.tabsBackground": "#00000000",
    "editorGroupHeader.noTabsBackground": "#00000000",
    "tab.activeBackground": "#00000000",
    "tab.inactiveBackground": "#00000000",
    "panel.background": "#00000000",
    "terminal.background": "#00000000",
    "window.activeBorder": "#00000000",
    "window.inactiveBorder": "#00000000",
    "minimap.background": "#00000000",
    "editorLineNumber.foreground": "#4b6a88",
    "editorLineNumber.activeForeground": "#ffffff",
    "focusBorder": "#00c3ff80",
    "selection.background": "#00c3ff40",
    "editor.selectionBackground": "#00c3ff33",
    "editorCursor.foreground": "#00c3ff",
    "textLink.foreground": "#00c3ff",
    "list.hoverBackground": "#ffffff0a",
    "list.activeSelectionBackground": "#00c3ff26"
  },
  "semanticTokenColors": {
    "namespace": "#00c3ff",
    "class": "#00e8c8",
    "enum": "#f5c842",
    "interface": "#4db8ff",
    "struct": "#00e8c8",
    "typeParameter": "#c870ff",
    "type": "#00e8c8",
    "parameter": "#ff7a90",
    "variable": "#e2ecf5",
    "property": "#4db8e8",
    "function": "#0aa68d",
    "method": "#38b8e8",
    "macro": "#c870ff",
    "decorator": "#8878f8"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#6389a6",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": ["string", "punctuation.definition.string"],
      "settings": {
        "foreground": "#0ddb9d"
      }
    },
    {
      "name": "Keywords & Control",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier",
        "keyword.control"
      ],
      "settings": {
        "foreground": "#ff5fa8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#f5c842"
      }
    },
    {
      "name": "Functions",
      "scope": ["entity.name.function", "meta.function-call"],
      "settings": {
        "foreground": "#00c3ff",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Classes and Types",
      "scope": ["entity.name.type", "entity.name.class", "support.class"],
      "settings": {
        "foreground": "#00e8c8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#e2ecf5"
      }
    },
    {
      "name": "Constants",
      "scope": ["constant.numeric", "constant.language", "support.constant"],
      "settings": {
        "foreground": "#c870ff",
        "fontStyle": "bold"
      }
    },
    {
      "name": "HTML/XML Tags",
      "scope": ["entity.name.tag", "punctuation.definition.tag"],
      "settings": {
        "foreground": "#ff5fa8"
      }
    },
    {
      "name": "HTML/XML Attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#f5c842"
      }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation"],
      "settings": {
        "foreground": "#8cabcc"
      }
    }
  ]
}
