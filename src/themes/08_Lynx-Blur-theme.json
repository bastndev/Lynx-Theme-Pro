    "editorBracketMatch.background": "#00c8ff14",
    "editorBracketMatch.border": "#00c8ff55",

    "tab.activeBorderTop": "#00c8ff",
    "tab.activeBorder": "#00000000",
    "tab.unfocusedActiveBorderTop": "#00c8ff60",
    "tab.hoverBackground": "#ffffff0a",
    "tab.activeForeground": "#e8f4ff",
    "tab.inactiveForeground": "#8aabcc",
    "tab.unfocusedActiveForeground": "#a0c0e0",
    "tab.border": "#ffffff08",
    "breadcrumb.foreground": "#6a8aaa",
    "breadcrumb.focusForeground": "#c8e0f5",
    "breadcrumb.activeSelectionForeground": "#00c8ff",
    "breadcrumbPicker.background": "#0a0e1490",

    "sideBarTitle.foreground": "#8aabcc",
    "sideBarSectionHeader.foreground": "#7090b0",
    "sideBarSectionHeader.border": "#ffffff08",
    "list.hoverBackground": "#ffffff06",
    "list.activeSelectionBackground": "#00c8ff18",
    "list.activeSelectionForeground": "#e8f6ff",
    "list.inactiveSelectionBackground": "#00c8ff10",
    "list.inactiveSelectionForeground": "#c0d8f0",
    "list.focusBackground": "#00c8ff20",
    "list.focusForeground": "#e8f6ff",
    "list.highlightForeground": "#00c8ff",
    "list.dropBackground": "#00c8ff15",
    "tree.indentGuidesStroke": "#ffffff15",

    "activityBarBadge.background": "#00c8ff",
    "activityBarBadge.foreground": "#00080f",
    "activityBar.foreground": "#c8e0f5",
    "activityBar.inactiveForeground": "#6a90b8",
    "activityBar.border": "#ffffff08",
    "activityBar.activeBorder": "#00c8ff",
    "activityBar.activeBackground": "#00c8ff0a",
    "activityBar.activeFocusBorder": "#00c8ff",

    "statusBar.foreground": "#8aaac8",
    "statusBar.border": "#ffffff08",
    "statusBar.debuggingForeground": "#00c8ff",
    "statusBar.noFolderForeground": "#8aaac8",
    "statusBarItem.hoverBackground": "#00c8ff15",
    "statusBarItem.activeBackground": "#00c8ff25",
    "statusBarItem.remoteBackground": "#00c8ff30",
    "statusBarItem.remoteForeground": "#e8f4ff",

    "titleBar.activeForeground": "#8aaac8",
    "titleBar.inactiveForeground": "#4a6a88",
    "titleBar.border": "#ffffff08",

    "panel.border": "#ffffff08",
    "panelTitle.activeForeground": "#c8e0f5",
    "panelTitle.inactiveForeground": "#4a6a88",
    "panelTitle.activeBorder": "#00c8ff",

    "terminal.foreground": "#c8e0f5",
    "terminal.selectionBackground": "#00c8ff28",
    "terminal.findMatchBackground": "#00c8ff35",
    "terminal.findMatchHighlightBackground": "#00c8ff18",
    "terminalCursor.foreground": "#00c8ff",
    "terminalCursor.background": "#001822",
    "terminal.ansiBlack": "#1a2535",
    "terminal.ansiBlue": "#00c8ff",
    "terminal.ansiCyan": "#00e8c8",
    "terminal.ansiGreen": "#00dc82",
    "terminal.ansiMagenta": "#c870ff",
    "terminal.ansiRed": "#ff5076",
    "terminal.ansiWhite": "#c8d8e8",
    "terminal.ansiYellow": "#f5c842",
    "terminal.ansiBrightBlack": "#3a5570",
    "terminal.ansiBrightBlue": "#48d8ff",
    "terminal.ansiBrightCyan": "#44f0d8",
    "terminal.ansiBrightGreen": "#30f096",
    "terminal.ansiBrightMagenta": "#e090ff",
    "terminal.ansiBrightRed": "#ff7096",
    "terminal.ansiBrightWhite": "#e8f2fc",
    "terminal.ansiBrightYellow": "#ffd860",

    "editorWidget.background": "#0a0e14c2",
    "editorWidget.border": "#00c8ff30",
    "editorWidget.resizeBorder": "#00c8ff",
    "editorSuggestWidget.background": "#0a0e14c2",
    "editorSuggestWidget.border": "#ffffff14",
    "editorSuggestWidget.highlightForeground": "#00c8ff",
    "editorSuggestWidget.selectedBackground": "#00c8ff18",
    "editorSuggestWidget.foreground": "#c0d8f0",
    "editorHoverWidget.background": "#060a10e0",
    "editorHoverWidget.border": "#ffffff14",
    "editorHoverWidget.statusBarBackground": "#070b12e0",

    "quickInput.background": "#060a10e0",
    "quickInput.foreground": "#c8e0f5",
    "quickInputTitle.background": "#00c8ff12",
    "quickInputList.focusBackground": "#00c8ff20",
    "quickInputList.focusForeground": "#e8f4ff",
    "quickInputList.focusIconForeground": "#00c8ff",
    "pickerGroup.foreground": "#00c8ff",
    "pickerGroup.border": "#00c8ff25",

    "menu.background": "#06090fe0",
    "menu.foreground": "#c0d8f0",
    "menu.selectionBackground": "#00c8ff18",
    "menu.selectionForeground": "#e8f4ff",
    "menu.selectionBorder": "#00c8ff30",
    "menu.border": "#ffffff14",
    "menu.separatorBackground": "#ffffff10",
    "menubar.selectionBackground": "#00c8ff0f",
    "menubar.selectionForeground": "#c8e0f5",
    "menubar.selectionBorder": "#00c8ff25",

    "notifications.background": "#060a10e0",
    "notifications.border": "#ffffff14",
    "notificationCenterHeader.background": "#040710e0",
    "notificationCenterHeader.foreground": "#8aaac8",
    "notificationLink.foreground": "#00c8ff",
    "notificationsErrorIcon.foreground": "#ff5076",
    "notificationsWarningIcon.foreground": "#f5c842",
    "notificationsInfoIcon.foreground": "#00c8ff",

    "input.background": "#ffffff05",
    "input.border": "#ffffff14",
    "input.foreground": "#c8e0f5",
    "input.placeholderForeground": "#3a5570",
    "inputOption.activeBorder": "#00c8ff",
    "inputOption.activeBackground": "#00c8ff18",
    "inputOption.activeForeground": "#e8f4ff",
    "inputValidation.infoBorder": "#00c8ff",
    "inputValidation.infoBackground": "#00c8ff12",
    "inputValidation.warningBorder": "#f5c842",
    "inputValidation.warningBackground": "#f5c84212",
    "inputValidation.errorBorder": "#ff5076",
    "inputValidation.errorBackground": "#ff507612",
    "focusBorder": "#00c8ff55",
    "selection.background": "#00c8ff35",

    "button.background": "#00c8ffa0",
    "button.foreground": "#ffffff",
    "button.hoverBackground": "#00c8ffc0",
    "button.border": "#00c8ff40",
    "button.secondaryBackground": "#ffffff14",
    "button.secondaryForeground": "#c8e0f5",
    "button.secondaryHoverBackground": "#ffffff20",

    "scrollbar.shadow": "#00000040",
    "scrollbarSlider.background": "#ffffff0f",
    "scrollbarSlider.hoverBackground": "#ffffff20",
    "scrollbarSlider.activeBackground": "#00c8ff30",

    "diffEditor.insertedTextBackground": "#00dc820e",
    "diffEditor.removedTextBackground": "#ff50760e",
    "diffEditor.insertedLineBackground": "#00dc8208",
    "diffEditor.removedLineBackground": "#ff507608",
    "diffEditor.diagonalFill": "#ffffff08",

    "gitDecoration.addedResourceForeground": "#00dc82",
    "gitDecoration.modifiedResourceForeground": "#00c8ff",
    "gitDecoration.deletedResourceForeground": "#ff5076",
    "gitDecoration.untrackedResourceForeground": "#30f096",
    "gitDecoration.ignoredResourceForeground": "#3a5570",
    "gitDecoration.conflictingResourceForeground": "#f5c842",
    "gitDecoration.submoduleResourceForeground": "#c870ff",

    "badge.background": "#00c8ff30",
    "badge.foreground": "#00c8ff",

    "progressBar.background": "#00c8ff",

    "editorError.foreground": "#ff5076",
    "editorWarning.foreground": "#f5c842",
    "editorInfo.foreground": "#00c8ff",
    "editorHint.foreground": "#00e8c8",
    "editorError.border": "#ff507630",
    "editorWarning.border": "#f5c84230",
    "problemsErrorIcon.foreground": "#ff5076",
    "problemsWarningIcon.foreground": "#f5c842",
    "problemsInfoIcon.foreground": "#00c8ff",

    "minimap.findMatchHighlight": "#00c8fff5",
    "minimap.selectionHighlight": "#00c8ff55",
    "minimap.errorHighlight": "#ff5076",
    "minimap.warningHighlight": "#f5c842",
    "minimap.foregroundOpacity": "#000000c8",
    "minimapSlider.background": "#00c8ff0f",
    "minimapSlider.hoverBackground": "#00c8ff1e",
    "minimapSlider.activeBackground": "#00c8ff30",
    "minimapGutter.addedBackground": "#00dc82",
    "minimapGutter.modifiedBackground": "#00c8ff",
    "minimapGutter.deletedBackground": "#ff5076",

    "welcomePage.background": "#00000000",
    "welcomePage.tileBackground": "#ffffff06",
    "welcomePage.tileHoverBackground": "#00c8ff0a",
    "welcomePage.tileBorder": "#ffffff10",

    "extensionButton.prominentBackground": "#00c8ff90",
    "extensionButton.prominentForeground": "#ffffff",
    "extensionButton.prominentHoverBackground": "#00c8ffb0",
    "extensionBadge.remoteBackground": "#00c8ff30",
    "extensionBadge.remoteForeground": "#00c8ff",

    "settings.headerForeground": "#c8e0f5",
    "settings.modifiedItemIndicator": "#00c8ff",
    "settings.dropdownBackground": "#060a10e0",
    "settings.dropdownListBorder": "#00c8ff20",
    "settings.checkboxBackground": "#060a10e0",
    "settings.checkboxBorder": "#ffffff20",
    "settings.textInputBackground": "#ffffff05",
    "settings.textInputBorder": "#ffffff14",
    "settings.numberInputBackground": "#ffffff05",
    "settings.numberInputBorder": "#ffffff14",
    "settings.rowHoverBackground": "#ffffff04",
    "settings.focusedRowBackground": "#00c8ff06"
  },

  "semanticTokenColors": {
    "namespace": { "foreground": "#00c8ff" },
    "class": { "foreground": "#00e8c8" },
    "enum": { "foreground": "#f5c842" },
    "enumMember": { "foreground": "#ffd860" },
    "interface": { "foreground": "#4db8ff" },
    "struct": { "foreground": "#00e8c8" },
    "typeParameter": { "foreground": "#c870ff" },
    "type": { "foreground": "#00e8c8" },
    "parameter": { "foreground": "#ffaabb" },
    "variable": { "foreground": "#d0e8f8" },
    "variable.readonly": { "foreground": "#c870ff" },
    "property": { "foreground": "#6ac5e8" },
    "property.readonly": { "foreground": "#5ab0d8" },
    "function": { "foreground": "#18c89a" },
    "method": { "foreground": "#38b8e8" },
    "macro": { "foreground": "#c870ff" },
    "decorator": { "foreground": "#9888f8" },
    "label": { "foreground": "#f5c842" },
    "comment": { "foreground": "#4a7090", "fontStyle": "italic" },
    "string": { "foreground": "#0fe8a8" },
    "number": { "foreground": "#c870ff" },
    "regexp": { "foreground": "#ff8080" },
    "operator": { "foreground": "#f0c040" },
    "keyword": { "foreground": "#ff5fa8", "fontStyle": "bold" },
    "selfKeyword": { "foreground": "#ff5fa8", "fontStyle": "italic" }
  },

  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#4a7090", "fontStyle": "italic" }
    },
    {
      "name": "Comment — TODO / FIXME / NOTE",
      "scope": [
        "comment.line.todo",
        "comment.line.fixme",
        "keyword.codetag.notation"
      ],
      "settings": { "foreground": "#f5c842", "fontStyle": "bold italic" }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.quoted", "punctuation.definition.string"],
      "settings": { "foreground": "#0fe8a8" }
    },
    {
      "name": "Template Literals",
      "scope": [
        "string.template",
        "punctuation.definition.template-expression"
      ],
      "settings": { "foreground": "#16d8a0" }
    },
    {
      "name": "Template Expression Braces",
      "scope": [
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end"
      ],
      "settings": { "foreground": "#f0c040" }
    },
    {
      "name": "Keywords & Control Flow",
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type.class",
        "storage.type.function",
        "storage.type.interface",
        "storage.type.enum",
        "storage.type.namespace"
      ],
      "settings": { "foreground": "#ff5fa8", "fontStyle": "bold" }
    },
    {
      "name": "Storage Modifiers",
      "scope": [
        "storage.modifier",
        "keyword.control.as",
        "keyword.control.from",
        "keyword.control.import",
        "keyword.control.export"
      ],
      "settings": { "foreground": "#ff80b8" }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#f0c040" }
    },
    {
      "name": "Arithmetic & Comparison Operators",
      "scope": [
        "keyword.operator.arithmetic",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.bitwise"
      ],
      "settings": { "foreground": "#f5c842" }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic",
        "support.function"
      ],
      "settings": { "foreground": "#18c89a", "fontStyle": "bold" }
    },
    {
      "name": "Function Calls",
      "scope": ["meta.function-call"],
      "settings": { "foreground": "#20d8a8" }
    },
    {
      "name": "Classes & Types",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": { "foreground": "#00e8c8", "fontStyle": "bold" }
    },
    {
      "name": "Type Annotations & Generics",
      "scope": [
        "meta.type.annotation",
        "entity.name.type.alias",
        "entity.name.type.interface",
        "entity.name.type.enum",
        "support.type"
      ],
      "settings": { "foreground": "#44d8c8" }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other.readwrite"],
      "settings": { "foreground": "#d0e8f8" }
    },
    {
      "name": "Variables — Constant / Readonly",
      "scope": [
        "variable.other.constant",
        "variable.other.declaration",
        "support.variable.property.const"
      ],
      "settings": { "foreground": "#c870ff", "fontStyle": "bold" }
    },
    {
      "name": "Object Properties",
      "scope": [
        "variable.object.property",
        "meta.object.member",
        "support.variable.property",
        "meta.property.object"
      ],
      "settings": { "foreground": "#6ac5e8" }
    },
    {
      "name": "Constants — Numeric",
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#c870ff" }
    },
    {
      "name": "Constants — Language",
      "scope": ["constant.language"],
      "settings": { "foreground": "#c870ff", "fontStyle": "italic" }
    },
    {
      "name": "Constants — Other",
      "scope": ["support.constant", "constant.other"],
      "settings": { "foreground": "#d888ff" }
    },
    {
      "name": "Character Escape",
      "scope": ["constant.character.escape"],
      "settings": { "foreground": "#ff8080" }
    },
    {
      "name": "Regex",
      "scope": ["string.regexp"],
      "settings": { "foreground": "#ff8080" }
    },
    {
      "name": "Regex — Group / Quantifier",
      "scope": [
        "keyword.operator.quantifier.regexp",
        "punctuation.definition.group.regexp",
        "keyword.operator.or.regexp"
      ],
      "settings": { "foreground": "#f5c842" }
    },
    {
      "name": "HTML / XML Tags",
      "scope": ["entity.name.tag", "punctuation.definition.tag"],
      "settings": { "foreground": "#ff5fa8" }
    },
    {
      "name": "HTML / XML Attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#f5c842" }
    },
    {
      "name": "HTML — Attribute Values",
      "scope": ["string.quoted.double.html", "string.quoted.single.html"],
      "settings": { "foreground": "#0fe8a8" }
    },
    {
      "name": "CSS — Selector Element",
      "scope": ["entity.name.tag.css"],
      "settings": { "foreground": "#ff5fa8" }
    },
    {
      "name": "CSS — Property",
      "scope": ["support.type.property-name"],
      "settings": { "foreground": "#6ac5e8" }
    },
    {
      "name": "CSS — Property Value / Function",
      "scope": [
        "support.function.transform.css",
        "support.constant.property-value.css",
        "constant.other.color.rgb-value.css",
        "support.function.misc.css"
      ],
      "settings": { "foreground": "#0fe8a8" }
    },
    {
      "name": "CSS — Units",
      "scope": ["keyword.other.unit"],
      "settings": { "foreground": "#c870ff" }
    },
    {
      "name": "JSON — Keys",
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#6ac5e8" }
    },
    {
      "name": "Markdown — Heading",
      "scope": ["markup.heading", "punctuation.definition.heading.markdown"],
      "settings": { "foreground": "#00c8ff", "fontStyle": "bold" }
    },
    {
      "name": "Markdown — Bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#c8e0f5", "fontStyle": "bold" }
    },
    {
      "name": "Markdown — Italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#d0c8f0", "fontStyle": "italic" }
    },
    {
      "name": "Markdown — Code",
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": { "foreground": "#0fe8a8" }
    },
    {
      "name": "Markdown — Link",
      "scope": ["markup.underline.link", "string.other.link.title.markdown"],
      "settings": { "foreground": "#00c8ff" }
    },
    {
      "name": "Markdown — Quote",
      "scope": ["markup.quote"],
      "settings": { "foreground": "#4a7090", "fontStyle": "italic" }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation"],
      "settings": { "foreground": "#4a6070" }
    },
    {
      "name": "Punctuation — Brackets",
      "scope": [
        "punctuation.section.block",
        "punctuation.definition.block",
        "meta.brace.square",
        "meta.brace.round"
      ],
      "settings": { "foreground": "#7090a8" }
    },
    {
      "name": "Decorator / Annotation",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator"
      ],
      "settings": { "foreground": "#9888f8" }
    },
    {
      "name": "this / self / super",
      "scope": [
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": { "foreground": "#ff5fa8", "fontStyle": "italic" }
    },
    {
      "name": "Deprecated",
      "scope": ["invalid.deprecated"],
      "settings": { "foreground": "#f5c842", "fontStyle": "strikethrough" }
    },
    {
      "name": "Invalid",
      "scope": ["invalid"],
      "settings": { "foreground": "#ff5076", "fontStyle": "underline" }
    }
  ]
}
